# ============================================================
# BakeFlow ERP — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── App Identity ──────────────────────────────────────────────
BUSINESS_NAME=BakeFlow
BUSINESS_PHONE=+91 XXXXX XXXXX
OWNER_NAME=User

# ── PostgreSQL / Neon Database ────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection string
# It looks like:
#   postgresql://user:password@ep-cool-frog-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_v2oHcO6BxdKU@ep-gentle-feather-auz7nmx9.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require
# ── Google Sign-In (OAuth) ────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-long-random-secret-here
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ── Admin Password ────────────────────────────────────────────
ADMIN_PASSWORD=change-me-in-production

# ── Gemini AI (raw material invoice scanning) ─────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Twilio WhatsApp (customer invoice delivery) ───────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
